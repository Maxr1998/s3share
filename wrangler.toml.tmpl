name = "s3share"
compatibility_date = "2026-03-12"
compatibility_flags = ["nodejs_compat"]
main = "./worker/index.js"

[assets]
directory = "./dist"
not_found_handling = "single-page-application"
run_worker_first = ["/download"]

[[routes]]
pattern = ""
custom_domain = true

[vars]
S3_BUCKET = ""
S3_ENDPOINT = ""

[[kv_namespaces]]
id = ""
binding = "METADATA"
remote = true

[[kv_namespaces]]
id = ""
binding = "UPLOAD_SESSIONS"
remote = true